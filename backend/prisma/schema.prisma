generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model usuario {
  id     Int     @id @default(autoincrement())
  nome   String  @db.VarChar(120)
  email  String  @unique @db.VarChar(120)
  senha  String  @db.VarChar(120)
  perfil String? @default("OPERADOR") @db.VarChar(20)
}

model categoria {
  id      Int       @id @default(autoincrement())
  nome    String    @unique @db.VarChar(80)
  produto produto[]
}

model fornecedor {
  id      Int       @id @default(autoincrement())
  nome    String    @db.VarChar(120)
  cnpj    String?   @db.VarChar(20)
  cidade  String?   @db.VarChar(80)
  pedido  pedido[]
  produto produto[]
}

model produto {
  id                 Int                 @id @default(autoincrement())
  nome               String              @db.VarChar(120)
  sku                String              @unique @db.VarChar(40)
  tipo               String?             @default("COMUM") @db.VarChar(20)
  preco_custo        Decimal?            @default(0) @db.Decimal(12, 2)
  preco_venda        Decimal?            @default(0) @db.Decimal(12, 2)
  quantidade         Int?                @default(0)
  estoque_minimo     Int?                @default(0)
  validade           DateTime?           @db.Date
  garantia_meses     Int?
  categoria_id       Int?
  fornecedor_id      Int?
  movimentacao       movimentacao[]
  pedido_item        pedido_item[]
  categoria          categoria?          @relation(fields: [categoria_id], references: [id], onUpdate: NoAction)
  fornecedor         fornecedor?         @relation(fields: [fornecedor_id], references: [id], onUpdate: NoAction)
  produto_eletronico produto_eletronico?
  produto_perecivel  produto_perecivel?
}

model movimentacao {
  id         Int       @id @default(autoincrement())
  produto_id Int
  tipo       String    @db.VarChar(20)
  quantidade Int
  data_mov   DateTime? @default(now()) @db.Timestamp(6)
  produto    produto   @relation(fields: [produto_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model produto_perecivel {
  id                Int      @id @default(autoincrement())
  produto_id        Int      @unique
  lote              String   @db.VarChar(40)
  validade          DateTime @db.Date
  temperatura_ideal Decimal? @db.Decimal(5, 2)
  produto           produto  @relation(fields: [produto_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model produto_eletronico {
  id             Int     @id @default(autoincrement())
  produto_id     Int     @unique
  voltagem       String? @db.VarChar(10)
  garantia_meses Int?    @default(12)
  fabricante     String? @db.VarChar(80)
  produto        produto @relation(fields: [produto_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model pedido {
  id            Int           @id @default(autoincrement())
  fornecedor_id Int
  data_pedido   DateTime?     @default(now()) @db.Timestamp(6)
  status        String        @default("ABERTO") @db.VarChar(20)
  fornecedor    fornecedor    @relation(fields: [fornecedor_id], references: [id], onUpdate: NoAction)
  pedido_item   pedido_item[]
}

model pedido_item {
  id             Int     @id @default(autoincrement())
  pedido_id      Int
  produto_id     Int
  quantidade     Int
  preco_unitario Decimal @default(0) @db.Decimal(12, 2)
  pedido         pedido  @relation(fields: [pedido_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  produto        produto @relation(fields: [produto_id], references: [id], onUpdate: NoAction)
}
